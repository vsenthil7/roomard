# Roomard environment variables (example). Copy to .env.local for local dev.
# Never commit .env.local; secrets manager owns production values.

# Environment
NODE_ENV=development
LOG_LEVEL=debug
APP_VERSION=0.1.0
DEPLOYMENT_REGION=local

# Database
DATABASE_URL=postgresql://roomard:roomard_dev_pwd@localhost:5432/roomard
DATABASE_POOL_MAX=10
DATABASE_POOL_MIN=2
DATABASE_STATEMENT_TIMEOUT_MS=30000

# Redis
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=roomard:

# Object store (MinIO locally, Baidu BOS / S3 in production)
OBJECT_STORE_ENDPOINT=http://localhost:9000
OBJECT_STORE_REGION=eu-local
OBJECT_STORE_ACCESS_KEY=roomard_minio
OBJECT_STORE_SECRET_KEY=roomard_minio_dev_pwd
OBJECT_STORE_BUCKET_EVIDENCE=roomard-evidence
OBJECT_STORE_BUCKET_AUDIT=roomard-audit
OBJECT_STORE_FORCE_PATH_STYLE=true

# JWT signing keys (RS256). Generate with: openssl genrsa -out private.pem 2048
# For dev, an auto-generated keypair is used if these are unset.
JWT_PRIVATE_KEY_PATH=
JWT_PUBLIC_KEY_PATH=
JWT_ISSUER=https://api.roomard.local
JWT_AUDIENCE=roomard
JWT_ACCESS_TOKEN_TTL_SEC=3600
JWT_REFRESH_TOKEN_TTL_SEC=86400

# Service ports
API_GATEWAY_PORT=3000
AUTH_SVC_PORT=3001
TENANT_SVC_PORT=3002
GUEST_SVC_PORT=3003
CAPTURE_SVC_PORT=3004
INGEST_SVC_PORT=3005
BRIEF_SVC_PORT=3006
EXCEPTION_SVC_PORT=3007
AUDIT_SVC_PORT=3008
AI_GATEWAY_PORT=3009

# AI / Qianfan (Baidu) — placeholders; supply real keys at deploy time
QIANFAN_API_KEY=
QIANFAN_SECRET_KEY=
QIANFAN_BASE_URL=https://qianfan.baidubce.com
QIANFAN_REGION=ap-southeast-1
ERNIE_45_MODEL=ernie-4.5-turbo
ERNIE_X1_MODEL=ernie-x1
PADDLE_OCR_VL_ENDPOINT=
AI_GATEWAY_MOCK=true # set false in production

# SMTP (Mailpit locally; Postmark/SES in production)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@roomard.local

# Mews PMS (sandbox creds supplied per integration)
MEWS_API_BASE_URL=https://api.mews-demo.com
MEWS_WEBHOOK_SECRET=

# Frontend
WEB_API_BASE_URL=http://localhost:3000/v1
WEB_APP_PORT=5173

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAMESPACE=roomard
SENTRY_DSN=

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000
