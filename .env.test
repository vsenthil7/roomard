# Test environment — used by Vitest and Playwright.
NODE_ENV=test
LOG_LEVEL=error
DATABASE_URL=postgresql://roomard:roomard_dev_pwd@localhost:5432/roomard_test
REDIS_URL=redis://localhost:6379/1
REDIS_KEY_PREFIX=roomard_test:
OBJECT_STORE_ENDPOINT=http://localhost:9000
OBJECT_STORE_ACCESS_KEY=roomard_minio
OBJECT_STORE_SECRET_KEY=roomard_minio_dev_pwd
OBJECT_STORE_BUCKET_EVIDENCE=roomard-evidence-test
OBJECT_STORE_BUCKET_AUDIT=roomard-audit-test
OBJECT_STORE_FORCE_PATH_STYLE=true
JWT_ISSUER=https://api.roomard.test
JWT_AUDIENCE=roomard
AI_GATEWAY_MOCK=true
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=test@roomard.test
