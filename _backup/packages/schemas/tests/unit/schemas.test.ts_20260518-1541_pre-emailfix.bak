import { describe, it, expect } from 'vitest';
import {
  UuidSchema,
  EmailSchema,
  PhoneE164Schema,
  CountryCodeSchema,
  ConfidenceSchema,
  IsoDateTimeSchema,
  IsoDateSchema,
} from '../../src/common.js';
import { GuestCreateRequestSchema, PreferenceSchema } from '../../src/guest.js';
import { CardCaptureRequestSchema, OcrResultSchema } from '../../src/capture.js';
import { BriefGenerateRequestSchema, BriefItemPrioritySchema } from '../../src/brief.js';
import { ExceptionPatchRequestSchema, ExceptionKindSchema } from '../../src/exception.js';
import { ReviewLinkRequestSchema } from '../../src/review.js';
import { PropertyCreateRequestSchema, TenantTierSchema } from '../../src/tenant.js';
import { AuditExportRequestSchema } from '../../src/audit.js';
import { PasswordLoginRequestSchema, LoginResponseSchema, TokenPairSchema } from '../../src/auth.js';

describe('common schemas', () => {
  it('accepts a valid UUID', () => {
    expect(UuidSchema.parse('00000000-0000-4000-8000-000000000001')).toBe(
      '00000000-0000-4000-8000-000000000001',
    );
  });

  it('rejects an invalid UUID', () => {
    expect(() => UuidSchema.parse('not-a-uuid')).toThrow();
  });

  it('lowercases emails', () => {
    expect(EmailSchema.parse('Foo@Bar.com')).toBe('foo@bar.com');
  });

  it('rejects emails longer than 320 chars', () => {
    expect(() => EmailSchema.parse('a'.repeat(311) + '@bar.com')).toThrow();
  });

  it('accepts E.164 phone numbers', () => {
    expect(PhoneE164Schema.parse('+447700900123')).toBe('+447700900123');
  });

  it('rejects non-E.164 phone numbers', () => {
    expect(() => PhoneE164Schema.parse('07700 900123')).toThrow();
  });

  it('uppercases ISO 3166-1 alpha-2 country codes', () => {
    expect(CountryCodeSchema.parse('gb')).toBe('GB');
  });

  it('rejects 3-letter country codes', () => {
    expect(() => CountryCodeSchema.parse('GBR')).toThrow();
  });

  it('accepts confidence between 0 and 1', () => {
    expect(ConfidenceSchema.parse({ value: 0.7, calibration: 'heuristic' })).toEqual({
      value: 0.7,
      calibration: 'heuristic',
    });
  });

  it('rejects confidence above 1', () => {
    expect(() => ConfidenceSchema.parse({ value: 1.1, calibration: 'heuristic' })).toThrow();
  });

  it('accepts ISO datetime', () => {
    expect(IsoDateTimeSchema.parse('2026-05-18T10:00:00.000Z')).toBe('2026-05-18T10:00:00.000Z');
  });

  it('accepts ISO date', () => {
    expect(IsoDateSchema.parse('2026-05-18')).toBe('2026-05-18');
  });

  it('rejects invalid ISO date format', () => {
    expect(() => IsoDateSchema.parse('18/05/2026')).toThrow();
  });
});

describe('guest schemas', () => {
  it('accepts a minimal guest create request', () => {
    const parsed = GuestCreateRequestSchema.parse({ displayName: 'Jane Smith' });
    expect(parsed.displayName).toBe('Jane Smith');
  });

  it('rejects empty display name', () => {
    expect(() => GuestCreateRequestSchema.parse({ displayName: '' })).toThrow();
  });

  it('validates a full preference', () => {
    const sample = {
      id: '00000000-0000-4000-8000-000000000001',
      guestId: '00000000-0000-4000-8000-000000000002',
      kind: 'pillow',
      polarity: 'requirement',
      detail: 'Two firm pillows',
      confidence: { value: 0.9, calibration: 'reinforced' },
      status: 'active',
      source: 'card_capture',
      firstObservedAt: '2026-05-18T10:00:00.000Z',
      lastReinforcedAt: '2026-05-18T10:00:00.000Z',
      reinforcementCount: 1,
      evidenceIds: ['00000000-0000-4000-8000-000000000003'],
    };
    expect(() => PreferenceSchema.parse(sample)).not.toThrow();
  });
});

describe('capture schemas', () => {
  it('validates a card capture request', () => {
    const sample = {
      propertyId: '00000000-0000-4000-8000-000000000010',
      metadata: {
        capturedAt: '2026-05-18T10:00:00.000Z',
        captureSurface: 'mobile_camera',
      },
    };
    expect(() => CardCaptureRequestSchema.parse(sample)).not.toThrow();
  });

  it('rejects an unknown capture surface', () => {
    const sample = {
      propertyId: '00000000-0000-4000-8000-000000000010',
      metadata: {
        capturedAt: '2026-05-18T10:00:00.000Z',
        captureSurface: 'fax',
      },
    };
    expect(() => CardCaptureRequestSchema.parse(sample)).toThrow();
  });

  it('validates OCR result with fields', () => {
    const sample = {
      rawText: 'Likes Earl Grey',
      fields: [{ name: 'preference', value: 'Earl Grey', confidence: 0.92 }],
      modelId: 'paddleocr-vl',
      durationMs: 412,
    };
    expect(() => OcrResultSchema.parse(sample)).not.toThrow();
  });
});

describe('brief schemas', () => {
  it('defaults force to false', () => {
    const parsed = BriefGenerateRequestSchema.parse({
      propertyId: '00000000-0000-4000-8000-000000000010',
    });
    expect(parsed.force).toBe(false);
  });

  it('accepts each priority enum value', () => {
    expect(BriefItemPrioritySchema.options).toEqual(['vip', 'attention', 'standard']);
  });
});

describe('exception schemas', () => {
  it('allows null assignedTo via patch', () => {
    const parsed = ExceptionPatchRequestSchema.parse({ assignedTo: null });
    expect(parsed.assignedTo).toBeNull();
  });

  it('enumerates all exception kinds', () => {
    expect(ExceptionKindSchema.options).toContain('low_confidence_ocr');
    expect(ExceptionKindSchema.options).toContain('identity_merge_candidate');
  });
});

describe('review schemas', () => {
  it('requires a guestId for link request', () => {
    expect(() => ReviewLinkRequestSchema.parse({})).toThrow();
  });
});

describe('tenant schemas', () => {
  it('accepts a property short code with valid charset', () => {
    expect(() =>
      PropertyCreateRequestSchema.parse({
        name: 'Hotel London',
        shortCode: 'LON-01',
        timezone: 'Europe/London',
      }),
    ).not.toThrow();
  });

  it('rejects lower-case short code', () => {
    expect(() =>
      PropertyCreateRequestSchema.parse({
        name: 'Hotel London',
        shortCode: 'lon-01',
        timezone: 'Europe/London',
      }),
    ).toThrow();
  });

  it('lists tenant tiers', () => {
    expect(TenantTierSchema.options).toEqual(['starter', 'growth', 'enterprise']);
  });
});

describe('audit schemas', () => {
  it('requires a reason for export', () => {
    expect(() =>
      AuditExportRequestSchema.parse({
        from: '2026-05-01T00:00:00.000Z',
        to: '2026-05-18T00:00:00.000Z',
        reason: 'short',
      }),
    ).toThrow();
  });

  it('accepts a valid export request', () => {
    expect(() =>
      AuditExportRequestSchema.parse({
        from: '2026-05-01T00:00:00.000Z',
        to: '2026-05-18T00:00:00.000Z',
        reason: 'DPO subject-access request 2026-018',
      }),
    ).not.toThrow();
  });
});

describe('auth schemas', () => {
  it('accepts an mfa_required login response', () => {
    const sample = { status: 'mfa_required' as const, mfaToken: 'x'.repeat(32) };
    expect(() => LoginResponseSchema.parse(sample)).not.toThrow();
  });

  it('rejects login without password', () => {
    expect(() => PasswordLoginRequestSchema.parse({ email: 'a@b.co' })).toThrow();
  });

  it('validates a token pair', () => {
    expect(() =>
      TokenPairSchema.parse({
        accessToken: 'a',
        refreshToken: 'r',
        accessTokenExpiresAt: '2026-05-18T10:00:00.000Z',
        refreshTokenExpiresAt: '2026-05-19T10:00:00.000Z',
        tokenType: 'Bearer',
      }),
    ).not.toThrow();
  });
});
